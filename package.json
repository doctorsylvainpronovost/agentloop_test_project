{
  "name": "weather-api-migrations",
  "private": true,
  "scripts": {
    "test": "npm run test:frontend && npm run test:backend && node --test tests/package-setup.test.mjs",
    "test:python": "python3 -m pytest",
    "test:node": "node --test migration-tooling.test.js",
    "test:all": "node --test migration-tooling.test.js && python3 -m pytest && npm run test:db:verification",
    "test:db:verification": "./scripts/verify_db_migration_and_cache_plan.sh",
    "test:frontend": "node --test tests/frontend-build.test.mjs",
    "test:backend": "python3 -m unittest discover -s tests -p test_backend.py",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "vite": "^7.1.4"
  }
}

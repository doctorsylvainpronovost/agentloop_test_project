{
  "name": "weather-webapp-scaffold",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "backend:dev": "uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "backend:start": "uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "test": "node --import tsx --test tests/*.test.js tests/*.test.ts tests/*.test.tsx && python3 -m unittest discover -s tests -p test_backend.py",
    "test:frontend": "node --import tsx --test tests/*.test.js tests/*.test.ts tests/*.test.tsx",
    "test:backend": "python3 -m unittest discover -s tests -p test_backend.py"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
